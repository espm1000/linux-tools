FROM golang:tip-alpine3.23 AS builder

COPY . /tools/
WORKDIR /tools
RUN go build -o tools.dev .

FROM debian:trixie-slim
RUN apt update && apt install -y sudo

COPY --from=builder /tools/internal/templates/ /tools/internal/templates/
COPY --from=builder /tools/tools.dev /tools/tools.dev

RUN useradd -m testuser
RUN usermod -aG sudo testuser
RUN echo "testuser:p" | chpasswd

WORKDIR /tools
USER testuser
