dn: cn=openldap_object_xps,cn=schema,cn=config
changetype: add
objectClass: olcSchemaConfig
cn: openldap_object_xps
olcObjectClasses: ( 1.3.6.1.4.1.2552.1.1.8.1 NAME 'xpsParameterSetting' SUP top STRUCTURAL MUST ( xpsParameter $ xpsVendor $ xpsProduct $ xpsName ) MAY xpsValue )
olcObjectClasses: ( 1.3.6.1.4.1.2552.1.1.8.2 NAME 'xpsObject' SUP top STRUCTURAL MUST ( xpsNumber $ xpsCategory $ xpsClass $ xpsGUID $ xpsUpdateBy $ xpsUpdateMethod $ xpsSortKey ) MAY ( xpsParent $ xpsTombstone $ xpsProperty ) )
olcObjectClasses: ( 1.3.6.1.4.1.2552.1.1.8.3 NAME 'xpsXIDKey' SUP top STRUCTURAL MUST ( xpsXID $ xpsIndexedObject ) )
olcObjectClasses: ( 1.3.6.1.4.1.2552.1.1.8.4 NAME 'xpsKey' SUP top STRUCTURAL MUST ( xpsKeyValue $ xpsIndexedObject ) )

