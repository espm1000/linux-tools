FROM golang:trixie AS builder

COPY . /tools/
WORKDIR /tools
RUN go build -o tools.dev .

FROM debian:bookworm-20260421
RUN apt update && apt install -y sudo

COPY --from=builder /tools/internal/templates/bashrc.template /tools/internal/templates/
COPY --from=builder /tools/tools.dev /tools/tools.dev

RUN useradd -m testuser
RUN usermod -aG sudo testuser
RUN echo "testuser:p" | chpasswd

WORKDIR /tools
USER testuser
